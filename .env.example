# Firebase Configuration
# Update these with your Firebase project details

VITE_PUBLIC_FIREBASE_API_KEY="your-api-key-here"
VITE_PUBLIC_FIREBASE_AUTH_DOMAIN="your-auth-domain.firebaseapp.com"
VITE_PUBLIC_FIREBASE_DATABASE_URL="https://your-database-url.firebaseio.com"
VITE_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
VITE_PUBLIC_FIREBASE_STORAGE_BUCKET="your-storage-bucket.appspot.com"
VITE_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
VITE_PUBLIC_FIREBASE_APP_ID="your-app-id"

# Development Server
# VITE_DEV_SERVER_PORT=3000
